# FisioClinic Scheduler - Configurações da Instalação
#
# CLINIC_TYPE define o modo de operação da aplicação:
#   escola     → Clínica Escola (padrão). Campos de pagamento ficam ocultos.
#   particular → Clínica Particular. Campos de forma de pagamento e valor são exibidos nos agendamentos.
#
# Para mudar o tipo, altere o valor abaixo e reinicie o servidor.

CLINIC_TYPE=escola
